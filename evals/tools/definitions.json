            }
          },
          "description": "Custom variations (for multivariate flags)"
        },
        "clientSideAvailability": {
          "type": "object",
          "properties": {
            "usingMobileKey": { "type": "boolean" },
            "usingEnvironmentId": { "type": "boolean" }
          },
          "description": "Client-side SDK availability"
        }
      },
      "required": ["projectKey", "key", "name"]
