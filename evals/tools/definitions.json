  {
    "name": "update-feature-flag",
    "description": "Update or toggle a feature flag in a specific environment. Pass {on: true} or {on: false} to flip targeting; pass `instructions` (semantic patch instructions) for richer changes (rules, fallthrough, etc.). Returns the previous and new state.",
    "input_schema": {
      "type": "object",
      "properties": {
        "projectKey": { "type": "string", "description": "The project key" },
        "flagKey": { "type": "string", "description": "The flag key" },
        "environmentKey": { "type": "string", "description": "Environment key" },
        "on": { "type": "boolean", "description": "Whether to turn targeting on or off" },
        "instructions": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Semantic patch instructions for richer changes"
        },
        "comment": { "type": "string", "description": "Optional comment for the audit log" }
      },
      "required": ["projectKey", "flagKey", "environmentKey"]
    }
  }
